---
import PageLayout from '../../layouts/PageLayout.astro';
import BreadCrumb from '../../components/shared/BreadCrumb.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import CTABand from '../../components/shared/CTABand.astro';

const directorio = [
  { name: 'Carlos Espinoza M.', cargo: 'Presidente del Directorio' },
  { name: 'María del Carmen López', cargo: 'Directora' },
  { name: 'José Luis Cárdenas', cargo: 'Director' },
  { name: 'Ana Patricia Ríos', cargo: 'Directora' },
  { name: 'Luis Enrique Vargas', cargo: 'Director' },
  { name: 'Rosa Elvira Mendoza', cargo: 'Directora' },
];
const gerencia = [
  { name: 'Fernando Rodríguez T.', cargo: 'Gerente General' },
  { name: 'Lucía Fernández V.', cargo: 'Gerente de Negocios' },
  { name: 'Pedro Sánchez R.', cargo: 'Gerente de Riesgos' },
  { name: 'Andrea Gutiérrez P.', cargo: 'Gerente de Finanzas' },
  { name: 'Mario Castillo L.', cargo: 'Gerente de Operaciones' },
  { name: 'Claudia Torres M.', cargo: 'Gerente Legal' },
];
const indicadores = [
  { num: 'S/ 4,200M', label: 'Activos totales' },
  { num: 'S/ 3,100M', label: 'Cartera de créditos' },
  { num: 'S/ 3,500M', label: 'Depósitos totales' },
  { num: '500K+', label: 'Clientes activos' },
  { num: '118', label: 'Agencias a nivel nacional' },
  { num: '2,400+', label: 'Colaboradores' },
];
---

<PageLayout title="Institucional — Más de 40 años impulsando el Perú | Caja Trujillo" description="Conoce nuestra historia, misión, visión, gobierno corporativo e indicadores de Caja Trujillo.">
  <!-- Hero -->
  <section class="inst-hero">
    <div class="inst-hero__glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:2">
      <BreadCrumb items={[{label:'Inicio',href:'/'},{label:'Institucional'}]} />
      <h1 class="inst-hero__title">Más de 40 años impulsando el norte del Perú</h1>
      <p class="inst-hero__sub">Caja Municipal de Ahorro y Crédito de Trujillo, líder en microfinanzas con presencia en 20 regiones.</p>
    </div>
  </section>

  <!-- Misión y Visión -->
  <section class="mv-sec"><div class="container">
    <div class="mv-grid">
      <div class="mv-card mv-card--red">
        <div class="mv-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
        <h3 class="mv-title">Misión</h3>
        <p class="mv-text">Brindar soluciones financieras accesibles, oportunas y seguras que impulsen el desarrollo de las personas, familias y emprendedores del Perú, contribuyendo al crecimiento económico y social de las comunidades donde operamos.</p>
      </div>
      <div class="mv-card mv-card--yellow">
        <div class="mv-icon mv-icon--yellow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg></div>
        <h3 class="mv-title">Visión</h3>
        <p class="mv-text">Ser la institución microfinanciera líder del Perú, reconocida por la excelencia de nuestros servicios, la innovación tecnológica y nuestro compromiso inquebrantable con la inclusión financiera de cada peruano.</p>
      </div>
    </div>
  </div></section>

  <!-- Indicadores -->
  <section class="ind-sec"><div class="container">
    <SectionHeader eyebrow="Cifras" title="Indicadores institucionales" align="center" />
    <div class="ind-grid">
      {indicadores.map(ind => (
        <div class="ind-card">
          <span class="ind-num">{ind.num}</span>
          <span class="ind-label">{ind.label}</span>
        </div>
      ))}
    </div>
  </div></section>

  <!-- Gobierno Corporativo -->
  <section class="gov-sec"><div class="container">
    <SectionHeader eyebrow="Transparencia" title="Gobierno corporativo" />
    <div class="gov-grid">
      <div>
        <h3 class="gov-group-title">Directorio</h3>
        <div class="people-grid">
          {directorio.map(p => (
            <div class="person-card">
              <div class="person-avatar"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              <span class="person-name">{p.name}</span>
              <span class="person-cargo">{p.cargo}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h3 class="gov-group-title">Gerencia</h3>
        <div class="people-grid">
          {gerencia.map(p => (
            <div class="person-card">
              <div class="person-avatar"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              <span class="person-name">{p.name}</span>
              <span class="person-cargo">{p.cargo}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div></section>

  <!-- Regulación -->
  <section class="reg-sec"><div class="container">
    <SectionHeader eyebrow="Regulación" title="Supervisión y transparencia" align="center" />
    <div class="reg-grid">
      {([
        { title: 'SBS', desc: 'Superintendencia de Banca, Seguros y AFP', icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>' },
        { title: 'FENACREP', desc: 'Federación Nacional de Cooperativas de Ahorro y Crédito', icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
        { title: 'Calificadoras', desc: 'AA+ Clasificación de riesgo por agencias especializadas', icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>' },
        { title: 'Memoria anual', desc: 'Informes financieros y de gestión auditados', icon: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>' },
      ] as const).map(item => (
        <div class="reg-card">
          <div class="reg-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} /></div>
          <h4 class="reg-name">{item.title}</h4>
          <p class="reg-desc">{item.desc}</p>
          <Button variant="outline" size="sm" href="#">Ver documento</Button>
        </div>
      ))}
    </div>
  </div></section>

  <CTABand />
</PageLayout>

<style>
  .inst-hero{background:var(--gray-950);padding:48px 0 60px;position:relative;overflow:hidden}
  .inst-hero__glow{position:absolute;bottom:-200px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(255,194,0,0.07) 0%,transparent 70%);pointer-events:none}
  .inst-hero__title{font-family:var(--font-head);font-weight:800;color:var(--white);font-size:clamp(1.8rem,3.5vw,2.6rem);letter-spacing:-0.04em;margin:12px 0;line-height:1.15;max-width:600px}
  .inst-hero__sub{font-size:15px;color:rgba(255,255,255,0.62);margin:0;max-width:520px}

  .mv-sec{background:var(--white);padding:72px 0}
  .mv-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  .mv-card{background:var(--gray-50);padding:32px;border-radius:var(--r-xl)}
  .mv-card--red{border-left:4px solid var(--red-500)}
  .mv-card--yellow{border-left:4px solid var(--yellow-500)}
  .mv-icon{width:48px;height:48px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
  .mv-icon svg{color:var(--red-500)}
  .mv-icon--yellow svg{color:var(--yellow-600)}
  .mv-title{font-family:var(--font-head);font-weight:700;font-size:18px;color:var(--gray-900);margin:0 0 8px}
  .mv-text{font-size:14px;color:var(--gray-600);margin:0;line-height:1.65}

  .ind-sec{background:var(--gray-50);padding:72px 0}
  .ind-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:32px}
  .ind-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--r-xl);padding:28px;text-align:center;transition:all .2s ease}
  .ind-card:hover{box-shadow:var(--shadow-sm);border-color:var(--red-200)}
  .ind-num{display:block;font-family:var(--font-head);font-weight:800;font-size:clamp(2rem,3vw,2.6rem);color:var(--red-500);letter-spacing:-0.04em;margin-bottom:4px}
  .ind-label{font-size:13px;color:var(--gray-600)}

  .gov-sec{background:var(--white);padding:72px 0}
  .gov-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:32px}
  .gov-group-title{font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--gray-900);margin:0 0 20px}
  .people-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .person-card{text-align:center}
  .person-avatar{width:56px;height:56px;border-radius:50%;background:var(--gray-200);display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
  .person-avatar svg{color:var(--gray-400)}
  .person-name{display:block;font-family:var(--font-head);font-weight:600;font-size:13px;color:var(--gray-900);line-height:1.3}
  .person-cargo{display:block;font-size:12px;color:var(--gray-600);margin-top:2px}

  .reg-sec{background:var(--gray-50);padding:72px 0}
  .reg-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:32px}
  .reg-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--r-lg);padding:24px;text-align:center}
  .reg-icon{width:52px;height:52px;display:flex;align-items:center;justify-content:center;background:var(--yellow-50);border:1px solid var(--yellow-100);border-radius:50%;margin:0 auto 14px}
  .reg-icon svg{color:var(--yellow-600)}
  .reg-name{font-family:var(--font-head);font-weight:700;font-size:14px;color:var(--gray-900);margin:0 0 4px}
  .reg-desc{font-size:12.5px;color:var(--gray-600);margin:0 0 12px;line-height:1.45}

  @media(max-width:768px){.mv-grid,.gov-grid{grid-template-columns:1fr}.ind-grid{grid-template-columns:repeat(2,1fr)}.reg-grid{grid-template-columns:repeat(2,1fr)}.people-grid{grid-template-columns:repeat(2,1fr)}}
</style>
