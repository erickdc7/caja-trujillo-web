---
import PageLayout from '../../layouts/PageLayout.astro';import BreadCrumb from '../../components/shared/BreadCrumb.astro';import Button from '../../components/ui/Button.astro';import SectionHeader from '../../components/ui/SectionHeader.astro';import Card from '../../components/ui/Card.astro';import CTABand from '../../components/shared/CTABand.astro';import CreditSimulator from '../../components/react/CreditSimulator';
import products from '../../data/products-negocios.json';
const product = products.find((x:any)=>x.slug==='microemprendedor')!;
const related = products.filter((x:any)=>x.slug!=='microemprendedor').slice(0,3);
const iconSvg:Record<string,string> = {Zap:'<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',Shield:'<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',TrendingUp:'<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',Clock:'<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',Search:'<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',Banknote:'<rect width="20" height="12" x="2" y="6" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/>'};
---
<PageLayout title={product.metaTitle} description={product.metaDesc}>
  <section class="prod-hero">
    <div class="prod-hero__glow" aria-hidden="true"></div>
    <div class="container prod-hero__inner">
      <div class="prod-hero__text">
        <BreadCrumb items={[{label:'Inicio',href:'/'},{label:'Para tu negocio',href:'/para-tu-negocio/'},{label:'Microemprendedor'}]} />
        <h1 class="prod-hero__title">Capital de trabajo para el negocio que nunca para</h1>
        <p class="prod-hero__desc">{product.shortDesc}</p>
        <div class="prod-hero__stats">
          <div class="prod-hero__stat"><span class="prod-hero__stat-num">S/ 500</span><span class="prod-hero__stat-label">Desde</span></div>
          <div class="prod-hero__stat"><span class="prod-hero__stat-num">48 meses</span><span class="prod-hero__stat-label">Hasta</span></div>
          <div class="prod-hero__stat"><span class="prod-hero__stat-num">24h</span><span class="prod-hero__stat-label">Respuesta</span></div>
        </div>
        <div class="prod-hero__btns"><Button variant="primary" size="lg" href="/simuladores" iconRight="ArrowRight">Solicitar crédito</Button><Button variant="ghost" size="lg" href="#requisitos">Ver requisitos</Button></div>
      </div>
      <div class="prod-hero__sim"><CreditSimulator client:visible initialAmount={10000} maxAmount={product.maxAmount} minAmount={product.minAmount} maxMonths={product.maxMonths} tea={product.tea} productName="Microemprendedor" ctaHref="/simuladores" /></div>
    </div>
  </section>
  <section class="benefits-sec"><div class="container"><SectionHeader eyebrow="Ventajas" title="¿Por qué elegir Microemprendedor?" />
    <div class="benefits-grid">{product.benefits?.map((b:any)=>(<div class="benefit-card"><div class="benefit-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconSvg[b.icon]||''}/></div><h3 class="benefit-title">{b.title}</h3><p class="benefit-desc">{b.desc}</p></div>))}</div>
  </div></section>
  <section class="req-sec" id="requisitos"><div class="container"><SectionHeader eyebrow="Requisitos" title="¿Qué necesitas?" />
    <div class="req-grid"><ul class="req-list" role="list">{product.requirements?.map((r:string)=>(<li class="req-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="req-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg><span>{r}</span></li>))}</ul>
    <div class="req-contact"><h3 class="req-contact__title">¿Tienes dudas? Contáctanos</h3><div class="req-contact__list"><div class="req-contact__item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>Llámanos: 0800-41-888</div><div class="req-contact__item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>Visita tu agencia más cercana</div></div></div></div>
  </div></section>
  <section class="related-sec"><div class="container"><h2 class="related-title">También te puede interesar</h2><div class="related-grid">{related.map((p:any)=><Card product={p} />)}</div></div></section>
  <CTABand />
</PageLayout>
<style>
  .prod-hero{background-color:var(--gray-950);min-height:400px;position:relative;overflow:hidden}.prod-hero__glow{position:absolute;top:-200px;left:-200px;width:800px;height:800px;background:radial-gradient(circle,rgba(255,9,1,0.14)0%,transparent 70%);pointer-events:none}.prod-hero__inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr 380px;gap:48px;padding:80px 0}.prod-hero__title{font-family:var(--font-head);font-weight:800;color:var(--white);font-size:clamp(1.8rem,3.5vw,2.4rem);letter-spacing:-0.04em;margin:12px 0;line-height:1.15}.prod-hero__desc{font-size:16px;color:rgba(255,255,255,0.65);margin:0 0 20px;line-height:1.6}.prod-hero__stats{display:flex;gap:24px;padding:16px 0;border-top:1px solid rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);margin-bottom:24px}.prod-hero__stat-num{display:block;font-family:var(--font-head);font-weight:700;font-size:18px;color:var(--white)}.prod-hero__stat-label{font-size:12px;color:rgba(255,255,255,0.50)}.prod-hero__btns{display:flex;gap:12px;flex-wrap:wrap}.prod-hero__sim{display:flex;align-items:center}
  .benefits-sec{background:var(--white);padding:72px 0}.benefits-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px}.benefit-card{padding:24px;border:1px solid var(--gray-200);border-radius:var(--r-lg);transition:all .2s ease}.benefit-card:hover{box-shadow:var(--shadow-sm);border-color:var(--red-200)}.benefit-icon{width:52px;height:52px;display:flex;align-items:center;justify-content:center;background:var(--red-50);border:1px solid var(--red-100);border-radius:14px;margin-bottom:14px}.benefit-icon svg{color:var(--red-500)}.benefit-title{font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--gray-900);margin:0 0 6px}.benefit-desc{font-size:14px;color:var(--gray-600);margin:0;line-height:1.5}
  .req-sec{background:var(--white);padding:72px 0}.req-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:32px}.req-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:14px}.req-item{display:flex;align-items:center;gap:10px;font-size:14.5px;color:var(--gray-700);font-weight:500}.req-check{color:var(--red-500);flex-shrink:0}.req-contact{background:var(--red-50);border:1px solid var(--red-200);border-radius:var(--r-xl);padding:28px}.req-contact__title{font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--red-600);margin:0 0 16px}.req-contact__list{display:flex;flex-direction:column;gap:12px}.req-contact__item{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--gray-700);font-weight:500}.req-contact__item svg{color:var(--red-500);flex-shrink:0}
  .related-sec{background:var(--gray-50);padding:48px 0}.related-title{font-family:var(--font-head);font-weight:700;font-size:20px;color:var(--gray-900);margin:0 0 24px}.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  @media(max-width:768px){.prod-hero__inner{grid-template-columns:1fr;padding:48px 0}.prod-hero__sim{display:none}.benefits-grid,.req-grid,.related-grid{grid-template-columns:1fr}}
</style>
