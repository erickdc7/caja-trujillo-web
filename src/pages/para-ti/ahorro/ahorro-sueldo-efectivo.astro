---
import PageLayout from '../../../layouts/PageLayout.astro';
---

<PageLayout title="Ahorro Sueldo Efectivo | Caja Trujillo" description="Ahorro Sueldo Efectivo - Caja Municipal de Ahorro y Crédito de Trujillo">
  <section class="stub-hero">
    <div class="container">
      <h1 class="stub-hero__title">Ahorro Sueldo Efectivo</h1>
    </div>
  </section>
</PageLayout>

<style>
  .stub-hero {
    background-color: var(--gray-950);
    min-height: 200px;
    display: flex;
    align-items: center;
  }
  .stub-hero__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
  }
</style>
