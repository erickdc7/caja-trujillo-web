---
import PageLayout from '../../../layouts/PageLayout.astro';
import BreadCrumb from '../../../components/shared/BreadCrumb.astro';
import SectionHeader from '../../../components/ui/SectionHeader.astro';
import Button from '../../../components/ui/Button.astro';
import CTABand from '../../../components/shared/CTABand.astro';
import products from '../../../data/products-personas.json';
const p = products.find((x: any) => x.slug === 'cuenta-simple')!;
---
<PageLayout title={p.metaTitle} description={p.metaDesc}>
  <section class="page-hero"><div class="container">
    <BreadCrumb items={[{label:'Inicio',href:'/'},{label:'Para ti',href:'/para-ti/'},{label:'Cuenta Simple'}]} />
    <h1 class="page-hero__title">Tu cuenta sin comisiones, sin complicaciones</h1>
    <p class="page-hero__sub">{p.shortDesc}</p>
    <div class="page-hero__btns"><Button variant="primary" size="lg" href="/canales-digitales/" iconRight="ArrowRight">Abrir cuenta</Button><Button variant="ghost" size="lg" href="/para-ti/">Ver más productos</Button></div>
  </div></section>
  <section class="benefits-sec"><div class="container">
    <SectionHeader eyebrow="Ventajas" title="¿Por qué elegir Cuenta Simple?" />
    <div class="benefits-grid">{p.benefits?.map((b:any)=>(<div class="benefit-card"><h3 class="benefit-title">{b.title}</h3><p class="benefit-desc">{b.desc}</p></div>))}</div>
  </div></section>
  <CTABand />
</PageLayout>
<style>
  .page-hero{background-color:var(--gray-950);padding:60px 0 72px}
  .page-hero__title{font-family:var(--font-head);font-weight:800;color:var(--white);font-size:clamp(1.8rem,3.5vw,2.6rem);letter-spacing:-0.04em;margin:12px 0;line-height:1.15}
  .page-hero__sub{font-size:15px;color:rgba(255,255,255,0.62);margin:0 0 24px;max-width:520px}
  .page-hero__btns{display:flex;gap:12px;flex-wrap:wrap}
  .benefits-sec{background:var(--white);padding:72px 0}
  .benefits-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:32px}
  .benefit-card{padding:24px;border:1px solid var(--gray-200);border-radius:var(--r-lg);transition:all .2s ease}
  .benefit-card:hover{box-shadow:var(--shadow-sm);border-color:var(--red-200)}
  .benefit-title{font-family:var(--font-head);font-weight:700;font-size:16px;color:var(--gray-900);margin:0 0 6px}
  .benefit-desc{font-size:14px;color:var(--gray-600);margin:0;line-height:1.5}
  @media(max-width:768px){.benefits-grid{grid-template-columns:1fr}}
</style>
