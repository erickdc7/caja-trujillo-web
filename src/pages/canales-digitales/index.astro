---
import PageLayout from '../../layouts/PageLayout.astro';
import BreadCrumb from '../../components/shared/BreadCrumb.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTABand from '../../components/shared/CTABand.astro';
---

<PageLayout title="Canales Digitales — Todo Caja Trujillo en tu mano | Caja Trujillo" description="App móvil, Homebanking, cajeros ATM, agentes corresponsales y YAPE. Opera desde donde estés.">

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <BreadCrumb items={[{label:'Inicio',href:'/'},{label:'Canales digitales'}]} />
      <h1 class="page-hero__title">Todo Caja Trujillo en la palma de tu mano</h1>
      <p class="page-hero__sub">Realiza tus operaciones bancarias desde cualquier lugar, a cualquier hora, con total seguridad.</p>
      <div class="page-hero__btns">
        <Button variant="primary" size="lg" href="/canales-digitales/app-movil" iconRight="ArrowRight">Descargar App</Button>
        <Button variant="ghost" size="lg" href="/canales-digitales/homebanking">Ir a Homebanking</Button>
      </div>
    </div>
  </section>

  <!-- App Móvil -->
  <section class="app-sec">
    <div class="container app-grid">
      <div class="app-text">
        <span class="app-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
          App Móvil
        </span>
        <h2 class="app-title">Tu banco en el bolsillo, siempre contigo</h2>
        <p class="app-desc">Consulta saldos, transfiere, paga servicios y más desde tu smartphone con autenticación biométrica.</p>
        <ul class="app-features" role="list">
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Saldos y movimientos en tiempo real</li>
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Transferencias interbancarias al instante</li>
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Pago de servicios y recargas</li>
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Biometría y doble factor de seguridad</li>
        </ul>
        <div class="app-downloads">
          <a href="#" class="dl-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83"/><path d="M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/></svg>App Store</a>
          <a href="#" class="dl-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.899l2.557 1.477c.676.39.676 1.04 0 1.43l-2.557 1.477-2.67-2.692 2.67-2.692zM5.864 2.658L16.8 8.991l-2.302 2.302-8.634-8.635z"/></svg>Google Play</a>
        </div>
      </div>
      <div class="app-mockup"><div class="phone-mock"><span>Vista previa App</span></div></div>
    </div>
  </section>

  <!-- Homebanking -->
  <section class="hb-sec">
    <div class="container hb-grid">
      <div class="hb-mockup"><div class="browser-mock"><div class="browser-bar"><span class="browser-dot"></span><span class="browser-dot"></span><span class="browser-dot"></span><span class="browser-url">homebanking.cajatrujillo.com.pe</span></div><div class="browser-body"><span>Vista previa Homebanking</span></div></div></div>
      <div class="hb-text">
        <span class="app-badge app-badge--red"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>Homebanking</span>
        <h2 class="app-title">Banca en línea para ti y tu empresa</h2>
        <p class="app-desc">Gestiona tu cuenta personal o empresarial desde cualquier navegador web.</p>
        <h4 class="hb-subtitle">Para personas</h4>
        <ul class="app-features" role="list">
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Consulta de saldos y movimientos</li>
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Transferencias y pagos de servicios</li>
        </ul>
        <h4 class="hb-subtitle">Para empresas</h4>
        <ul class="app-features" role="list">
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>Pago de planillas y proveedores</li>
          <li class="app-feature"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="app-check"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>E-commerce y pagos online seguros</li>
        </ul>
        <div class="hb-btns">
          <Button variant="primary" size="md" href="#">Ingresar Personas</Button>
          <Button variant="dark" size="md" href="#">Ingresar Empresas</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Cajeros y Agentes -->
  <section class="atm-sec">
    <div class="container">
      <SectionHeader eyebrow="Red física" title="Cajeros y agentes en todo el Perú" align="center" />
      <div class="atm-grid">
        <div class="atm-card">
          <div class="atm-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg></div>
          <h3 class="atm-name">Cajeros ATM</h3>
          <p class="atm-desc">Red de cajeros automáticos a nivel nacional para retiros, consultas y depósitos las 24 horas.</p>
        </div>
        <div class="atm-card">
          <div class="atm-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 class="atm-name">Agentes Corresponsales</h3>
          <p class="atm-desc">Miles de puntos autorizados en bodegas, farmacias y comercios para tus operaciones bancarias.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- YAPE -->
  <section class="yape-sec">
    <div class="container">
      <div class="yape-banner">
        <h2 class="yape-title">Vincula tu cuenta con YAPE</h2>
        <p class="yape-desc">Envía y recibe dinero de forma inmediata desde tu celular vinculando tu cuenta Caja Trujillo.</p>
        <Button variant="ghost" size="lg" href="#">Cómo vincular YAPE</Button>
      </div>
    </div>
  </section>

  <CTABand />
</PageLayout>

<style>
  .page-hero{background-color:var(--gray-950);min-height:260px;padding:48px 0 56px}
  .page-hero__title{font-family:var(--font-head);font-weight:800;color:var(--white);font-size:clamp(1.8rem,3.5vw,2.6rem);letter-spacing:-0.04em;margin:12px 0;line-height:1.15}
  .page-hero__sub{font-size:15px;color:rgba(255,255,255,0.62);margin:0 0 24px;max-width:520px}
  .page-hero__btns{display:flex;gap:12px;flex-wrap:wrap}

  .app-sec{background:var(--white);padding:80px 0}
  .app-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
  .app-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-size:12px;font-weight:600;background:var(--red-50);border:1px solid var(--red-200);color:var(--red-500);margin-bottom:16px}
  .app-badge--red{background:var(--red-500);border-color:var(--red-400);color:var(--white)}
  .app-title{font-family:var(--font-head);font-weight:800;font-size:clamp(1.4rem,2.5vw,1.8rem);color:var(--gray-900);letter-spacing:-0.03em;margin:0 0 10px;line-height:1.2}
  .app-desc{font-size:14px;color:var(--gray-600);margin:0 0 20px;line-height:1.6}
  .app-features{list-style:none;margin:0 0 20px;padding:0;display:flex;flex-direction:column;gap:10px}
  .app-feature{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--gray-700);font-weight:500}
  .app-check{color:var(--red-500);flex-shrink:0}
  .app-downloads{display:flex;gap:8px}
  .dl-btn{display:inline-flex;align-items:center;gap:6px;background:var(--gray-950);border:1px solid var(--gray-800);border-radius:9px;padding:9px 16px;color:var(--white);font-size:13px;font-weight:600;text-decoration:none;transition:all .2s ease}
  .dl-btn:hover{background:var(--gray-800);transform:translateY(-1px)}

  .phone-mock{width:280px;height:560px;background:var(--gray-100);border-radius:24px;border:8px solid var(--gray-200);box-shadow:var(--shadow-lg);display:flex;align-items:center;justify-content:center;margin:0 auto}
  .phone-mock span{color:var(--gray-400);font-size:14px}

  .hb-sec{background:var(--gray-50);padding:80px 0}
  .hb-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
  .hb-subtitle{font-family:var(--font-head);font-weight:700;font-size:13px;color:var(--gray-900);text-transform:uppercase;letter-spacing:0.05em;margin:16px 0 8px}
  .hb-btns{display:flex;gap:10px;margin-top:20px}
  .browser-mock{width:480px;max-width:100%;background:var(--white);border-radius:12px;box-shadow:var(--shadow-md);overflow:hidden;margin:0 auto}
  .browser-bar{background:var(--gray-100);padding:12px 16px;display:flex;align-items:center;gap:6px}
  .browser-dot{width:10px;height:10px;border-radius:50%;background:var(--gray-300)}
  .browser-url{margin-left:12px;font-size:11px;color:var(--gray-500);background:var(--white);padding:4px 12px;border-radius:4px;border:1px solid var(--gray-200)}
  .browser-body{height:260px;display:flex;align-items:center;justify-content:center}
  .browser-body span{color:var(--gray-400);font-size:14px}

  .atm-sec{background:var(--gray-50);padding:72px 0}
  .atm-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:32px}
  .atm-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--r-xl);padding:32px;transition:all .2s ease}
  .atm-card:hover{border-color:var(--red-200);box-shadow:var(--shadow-md)}
  .atm-icon{width:64px;height:64px;display:flex;align-items:center;justify-content:center;background:var(--red-50);border-radius:50%;margin-bottom:16px}
  .atm-icon svg{color:var(--red-500)}
  .atm-name{font-family:var(--font-head);font-weight:700;font-size:18px;color:var(--gray-900);margin:0 0 8px}
  .atm-desc{font-size:14px;color:var(--gray-600);margin:0;line-height:1.5}

  .yape-sec{padding:48px 0;background:var(--white)}
  .yape-banner{background:linear-gradient(135deg,#5B2D8E,#8B4FBF);border-radius:var(--r-xl);padding:48px;text-align:center}
  .yape-title{font-family:var(--font-head);font-weight:800;color:var(--white);font-size:clamp(1.4rem,2.5vw,2rem);margin:0 0 10px}
  .yape-desc{color:rgba(255,255,255,0.75);font-size:15px;margin:0 0 24px;max-width:480px;margin-left:auto;margin-right:auto}

  @media(max-width:768px){.app-grid,.hb-grid{grid-template-columns:1fr}.atm-grid{grid-template-columns:1fr}.phone-mock{width:220px;height:440px}}
</style>
