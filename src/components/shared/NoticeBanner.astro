---
/**
 * NoticeBanner — banner de aviso amarillo debajo del hero.
 */
import Button from '../ui/Button.astro';
---

<section class="notice" aria-label="Aviso importante">
  <div class="container notice__inner">
    <div class="notice__icon" aria-hidden="true">
      <!-- Bell icon -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
      </svg>
    </div>
    <div class="notice__text">
      <strong class="notice__title">Consulta tu nuevo número de cuenta de ahorro y crédito</strong>
      <span class="notice__desc">Actualización del sistema — verifica en línea sin ir a agencia</span>
    </div>
    <Button variant="secondary" size="sm" href="/para-ti/cuenta-simple" iconRight="ArrowRight">Consultar ahora</Button>
  </div>
</section>

<style>
  .notice { background-color: var(--yellow-50); border-bottom: 1px solid var(--yellow-200); padding: 14px 0; }
  .notice__inner { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .notice__icon { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background-color: var(--yellow-500); border-radius: var(--r-sm); flex-shrink: 0; }
  .notice__icon svg { color: var(--gray-900); }
  .notice__text { flex: 1; min-width: 200px; }
  .notice__title { display: block; font-size: 13.5px; font-weight: 700; color: #92620a; }
  .notice__desc { display: block; font-size: 12.5px; color: #a06f0c; opacity: 0.8; }
  @media (max-width: 768px) {
    .notice__inner { gap: 10px; }
  }
</style>
