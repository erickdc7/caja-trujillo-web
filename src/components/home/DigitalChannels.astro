---
/**
 * DigitalChannels — sección de canales digitales del homepage.
 */
import SectionHeader from '../ui/SectionHeader.astro';
---

<section class="digital" aria-label="Canales digitales">
  <div class="container">
    <SectionHeader
      eyebrow="Banca digital"
      title="Opera desde donde estés"
      subtitle="Gestiona tus finanzas en cualquier momento con la seguridad que mereces."
    />

    <div class="digital__grid">
      <!-- Card App -->
      <div class="digital__card digital__card--dark">
        <div class="digital__pattern" aria-hidden="true"></div>
        <div class="digital__circle" aria-hidden="true"></div>
        <div class="digital__body">
          <div class="digital__tag digital__tag--yellow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            App Móvil
          </div>
          <h3 class="digital__title">Tu banco en el bolsillo, siempre contigo</h3>
          <p class="digital__desc">Realiza todas tus operaciones desde tu smartphone con total seguridad.</p>
          <ul class="digital__features" role="list">
            <li class="digital__feature"><span class="digital__check digital__check--yellow" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Saldos y movimientos en tiempo real</li>
            <li class="digital__feature"><span class="digital__check digital__check--yellow" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Transferencias interbancarias al instante</li>
            <li class="digital__feature"><span class="digital__check digital__check--yellow" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Pago de servicios y recargas</li>
            <li class="digital__feature"><span class="digital__check digital__check--yellow" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Biometría y doble factor de seguridad</li>
          </ul>
          <div class="digital__downloads">
            <a href="#" class="digital__store-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83"/><path d="M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/></svg>
              App Store
            </a>
            <a href="#" class="digital__store-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.899l2.557 1.477c.676.39.676 1.04 0 1.43l-2.557 1.477-2.67-2.692 2.67-2.692zM5.864 2.658L16.8 8.991l-2.302 2.302-8.634-8.635z"/></svg>
              Google Play
            </a>
          </div>
        </div>
      </div>

      <!-- Card Homebanking -->
      <div class="digital__card digital__card--red">
        <div class="digital__pattern" aria-hidden="true"></div>
        <div class="digital__circle" aria-hidden="true"></div>
        <div class="digital__body">
          <div class="digital__tag digital__tag--white">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
            Homebanking
          </div>
          <h3 class="digital__title">Banca en línea para ti y tu empresa</h3>
          <p class="digital__desc">Gestiona tu cuenta personal o empresarial desde cualquier navegador.</p>
          <ul class="digital__features" role="list">
            <li class="digital__feature"><span class="digital__check digital__check--white" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Homebanking para personas naturales</li>
            <li class="digital__feature"><span class="digital__check digital__check--white" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Plataforma empresarial y pago de planillas</li>
            <li class="digital__feature"><span class="digital__check digital__check--white" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>E-commerce y pagos online seguros</li>
            <li class="digital__feature"><span class="digital__check digital__check--white" aria-hidden="true"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Historial completo de operaciones</li>
          </ul>
          <div class="digital__downloads">
            <a href="#" class="digital__store-btn">Personas</a>
            <a href="#" class="digital__store-btn">Empresas</a>
            <a href="#" class="digital__store-btn">Planillas</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .digital { background-color: var(--white); padding: 72px 0; }
  .digital__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 32px; }
  .digital__card { position: relative; border-radius: var(--r-2xl); padding: 36px; overflow: hidden; min-height: 300px; }
  .digital__card--dark { background-color: var(--gray-950); }
  .digital__card--red { background-color: var(--red-500); }
  .digital__pattern { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 28px 28px; pointer-events: none; }
  .digital__circle { position: absolute; bottom: -100px; right: -100px; width: 320px; height: 320px; border-radius: 50%; background-color: rgba(255,255,255,0.04); pointer-events: none; }
  .digital__body { position: relative; z-index: 1; }
  .digital__tag { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; margin-bottom: 18px; }
  .digital__tag--yellow { background-color: rgba(255,194,0,0.14); border: 1px solid rgba(255,194,0,0.28); color: var(--yellow-400); }
  .digital__tag--white { background-color: rgba(255,255,255,0.16); border: 1px solid rgba(255,255,255,0.28); color: var(--white); }
  .digital__title { font-family: var(--font-head); font-weight: 800; font-size: clamp(1.4rem,2.5vw,1.75rem); color: var(--white); letter-spacing: -0.03em; line-height: 1.2; margin: 0 0 10px; }
  .digital__desc { font-size: 13.5px; color: rgba(255,255,255,0.58); margin: 0 0 18px; line-height: 1.5; }
  .digital__features { list-style: none; margin: 0 0 22px; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .digital__feature { display: flex; align-items: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.72); font-weight: 500; }
  .digital__check { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; border-radius: 50%; flex-shrink: 0; }
  .digital__check--yellow { background-color: rgba(255,194,0,0.20); }
  .digital__check--yellow svg { color: var(--yellow-400); }
  .digital__check--white { background-color: rgba(255,255,255,0.18); }
  .digital__check--white svg { color: var(--white); }
  .digital__downloads { display: flex; gap: 8px; flex-wrap: wrap; }
  .digital__store-btn { display: inline-flex; align-items: center; gap: 6px; background-color: rgba(255,255,255,0.10); border: 1px solid rgba(255,255,255,0.18); border-radius: 9px; padding: 7px 14px; color: var(--white); font-size: 12px; font-weight: 600; text-decoration: none; transition: all 0.2s ease; }
  .digital__store-btn:hover { background-color: rgba(255,255,255,0.18); transform: translateY(-1px); }
  @media (max-width: 768px) { .digital__grid { grid-template-columns: 1fr; } }
</style>
