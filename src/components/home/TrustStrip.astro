---
/**
 * TrustStrip — franja oscura con indicadores de confianza.
 */
---

<section class="trust" aria-label="Indicadores de confianza">
  <div class="container trust__grid">
    <div class="trust__item fade-up">
      <span class="trust__num">42<span class="trust__plus">+</span></span>
      <span class="trust__label">Años impulsando emprendedores y familias peruanas</span>
    </div>
    <div class="trust__item fade-up">
      <span class="trust__num">500<span class="trust__plus">K</span></span>
      <span class="trust__label">Clientes activos en todo el Perú</span>
    </div>
    <div class="trust__item fade-up">
      <span class="trust__num">20</span>
      <span class="trust__label">Regiones con presencia de Caja Trujillo</span>
    </div>
    <div class="trust__item trust__item--last fade-up">
      <span class="trust__num">AA<span class="trust__red">+</span></span>
      <span class="trust__label">Calificación de riesgo SBS</span>
    </div>
  </div>
</section>

<style>
  .trust { background-color: var(--gray-950); padding: 52px 0; }
  .trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); text-align: center; }
  .trust__item { padding: 8px 16px; border-right: 1px solid rgba(255,255,255,0.07); }
  .trust__item--last { border-right: none; }
  .trust__num { display: block; font-family: var(--font-head); font-weight: 800; font-size: clamp(2rem,3vw,2.6rem); color: var(--white); letter-spacing: -0.05em; line-height: 1; margin-bottom: 8px; }
  .trust__plus { color: var(--yellow-500); }
  .trust__red { color: var(--red-500); }
  .trust__label { display: block; font-size: 12.5px; color: rgba(255,255,255,0.42); max-width: 140px; margin: 0 auto; line-height: 1.4; }
  @media (max-width: 768px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); }
    .trust__item { border-right: none; padding: 20px 16px; }
    .trust__item:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.07); }
    .trust__item:nth-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.07); }
  }
</style>
