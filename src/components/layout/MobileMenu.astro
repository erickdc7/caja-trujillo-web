---
/**
 * MobileMenu — menú de navegación móvil a pantalla completa.
 * Se muestra/oculta con la clase .open (toggle desde Navbar).
 */
import Button from '../ui/Button.astro';
---

<div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Menú de navegación" aria-modal="true">
  <!-- Botón cerrar -->
  <button
    class="mobile-menu__close"
    aria-label="Cerrar menú de navegación"
    id="mobile-menu-close"
  >
    <!-- X icon -->
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
    </svg>
  </button>

  <!-- Lista de navegación -->
  <nav aria-label="Navegación móvil">
    <ul class="mobile-menu__list" role="list">
      <li>
        <a href="/para-ti/" class="mobile-menu__link">
          <span>Para ti</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
      <li>
        <a href="/para-tu-negocio/" class="mobile-menu__link">
          <span>Para tu negocio</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
      <li>
        <a href="/canales-digitales/" class="mobile-menu__link">
          <span>Canales digitales</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
      <li>
        <a href="/institucional/" class="mobile-menu__link">
          <span>Institucional</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
      <li>
        <a href="/simuladores" class="mobile-menu__link">
          <span>Simuladores</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </li>
    </ul>
  </nav>

  <!-- Divisor -->
  <hr class="mobile-menu__divider" />

  <!-- Botones de acción -->
  <div class="mobile-menu__actions">
    <Button variant="dark" href="/canales-digitales/homebanking" fullWidth>Homebanking</Button>
    <Button variant="primary" href="/simuladores" fullWidth>Solicitar crédito</Button>
    <Button variant="outline" href="/para-ti/ahorro/cuenta-simple" fullWidth>Abrir cuenta gratis</Button>
  </div>
</div>

<script>
  function initMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-menu-close');
    const burger = document.getElementById('burger-btn');

    if (!menu) return;

    function closeMenu() {
      menu!.classList.remove('open');
      document.body.style.overflow = '';
      if (burger) {
        burger.setAttribute('aria-expanded', 'false');
        burger.focus();
      }
    }

    // Cerrar con botón X
    if (closeBtn) {
      closeBtn.addEventListener('click', closeMenu);
    }

    // Cerrar con Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu!.classList.contains('open')) {
        closeMenu();
      }
    });

    // Focus trapping dentro del menú
    menu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = menu!.querySelectorAll<HTMLElement>(
        'a[href], button, [tabindex]:not([tabindex="-1"])'
      );
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Al abrir, mover foco al botón cerrar
    const observer = new MutationObserver(() => {
      if (menu!.classList.contains('open') && closeBtn) {
        closeBtn.focus();
      }
    });
    observer.observe(menu, { attributes: true, attributeFilter: ['class'] });
  }

  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

<style>
  .mobile-menu {
    position: fixed;
    inset: 0;
    background-color: var(--white);
    z-index: 200;
    display: none;
    flex-direction: column;
    padding: 80px 24px 32px;
    overflow-y: auto;
  }

  .mobile-menu.open {
    display: flex;
  }

  /* ===================================================
     BOTÓN CERRAR
     =================================================== */
  .mobile-menu__close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--gray-100);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .mobile-menu__close svg {
    color: var(--gray-700);
  }

  .mobile-menu__close:hover {
    background-color: var(--red-50);
  }

  .mobile-menu__close:focus-visible {
    outline: 2px solid var(--red-500);
    outline-offset: 2px;
  }

  /* ===================================================
     LISTA DE LINKS
     =================================================== */
  .mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 13px 16px;
    border-radius: var(--r-md);
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-600);
    text-decoration: none;
    border: 1.5px solid transparent;
    transition: var(--transition);
  }

  .mobile-menu__link svg {
    opacity: 0.5;
    flex-shrink: 0;
  }

  .mobile-menu__link:hover {
    background-color: var(--red-50);
    color: var(--red-500);
    border-color: var(--red-200);
  }

  .mobile-menu__link:focus-visible {
    outline: 2px solid var(--red-500);
    outline-offset: 2px;
  }

  /* ===================================================
     DIVISOR
     =================================================== */
  .mobile-menu__divider {
    border: none;
    border-top: 1px solid var(--gray-200);
    margin: 6px 0;
  }

  /* ===================================================
     ACCIONES
     =================================================== */
  .mobile-menu__actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }
</style>
