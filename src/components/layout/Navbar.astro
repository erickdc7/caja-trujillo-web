  Users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <!-- Logo -->
    <a href="/" class="navbar__logo" aria-label="Caja Trujillo — Inicio">
      <img src="/caja-trujillo-logo.png" alt="Caja Trujillo" class="navbar__logo-img" width="160" height="40" />
    </a>

    <!-- Navegación principal -->
    <nav class="navbar__nav" aria-label="Navegación principal">
      <ul class="navbar__list" role="list">

        {/* ── Para ti — mega-menú de panel ancho ── */}
        <li class="navbar__item navbar__item--has-mega navbar__item--para-ti">
          <button
            class="navbar__link"
            aria-expanded="false"
            aria-controls="mega-para-ti"
            id="mega-para-ti-trigger"
            type="button"
          >
            Para ti
            <svg class="navbar__chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>

          <!-- Mega-menú panel -->
          <div class="mega-panel" id="mega-para-ti" role="menu" aria-label="Productos para ti">
            <div class="mega-panel__inner">
              {paraTiSections.map((section) => (
                <div class="mega-panel__section">
                  <div class="mega-panel__heading">
                    <span class="mega-panel__icon">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconSvg[section.icon] || ''} />
                    </span>
                    <span class="mega-panel__title">{section.title}</span>
                  </div>
                  <ul class="mega-panel__links" role="list">
                    {section.links.map((link) => (
                      <li>
                        <a href={link.href} class="mega-panel__link" role="menuitem">
                          {link.name}
                          {link.badge && <span class="mega-panel__badge">{link.badge}</span>}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            <div class="mega-panel__footer">
              <a href="/para-ti/" class="mega-panel__view-all">
                Ver todos los productos
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </li>

        {/* ── Para tu negocio / Canales — mega-menús legacy ── */}
        {legacyMegaMenus.map((menu) => (
          <li class="navbar__item navbar__item--has-mega">
            <a href={menu.href} class="navbar__link">
              {menu.label}
              <svg class="navbar__chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </a>

            <div class="mega" role="menu" aria-label={menu.title}>
              <span class="mega__title">{menu.title}</span>
              <div class="mega__grid">
                {menu.items.map((item) => (
                  <a href={item.href} class="mega__item" role="menuitem">
                    <div class="mega__icon">
                      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconSvg[item.icon] || ''} />
                    </div>
                    <div>
                      <span class="mega__name">{item.name}</span>
                      <span class="mega__desc">{item.desc}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </li>
        ))}

        {/* Ítems simples (sin mega-menú) */}
        {simpleLinks.map((link) => (
          <li class="navbar__item">
            <a href={link.href} class="navbar__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="navbar__actions">
      <Button variant="outline" size="sm" href="/para-ti/cuenta-simple">Abrir cuenta</Button>
      <Button variant="primary" size="sm" href="/simuladores" iconRight="ArrowRight">Solicitar crédito</Button>
    </div>

    <!-- Hamburguesa (mobile) -->
    <button
      class="navbar__burger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="burger-btn"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</header>

<script>
  function initNavbar() {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;

    // Scroll — agregar clase scrolled
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    }, { passive: true });

    /* ── Mega-menú "Para ti" — click to open/close ── */
    const paraTiTrigger = document.getElementById('mega-para-ti-trigger');
    const paraTiPanel = document.getElementById('mega-para-ti');

    if (paraTiTrigger && paraTiPanel) {
      paraTiTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = paraTiTrigger.getAttribute('aria-expanded') === 'true';
        closeMegaPanel();
        if (!isOpen) {
          paraTiTrigger.setAttribute('aria-expanded', 'true');
          paraTiPanel.classList.add('mega-panel--open');
        }
      });
    }

    function closeMegaPanel() {
      if (paraTiTrigger) paraTiTrigger.setAttribute('aria-expanded', 'false');
      if (paraTiPanel) paraTiPanel.classList.remove('mega-panel--open');
    }

    // Click outside closes
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.navbar__item--para-ti')) {
        closeMegaPanel();
      }
    });

    // Escape closes
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMegaPanel();
        if (paraTiTrigger) paraTiTrigger.focus();
      }
    });

    /* ── Legacy mega-menús (hover) — Escape cierra ── */
    const megaItems = navbar.querySelectorAll('.navbar__item--has-mega:not(.navbar__item--para-ti)');
    megaItems.forEach((item) => {
      item.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Escape') {
          const trigger = item.querySelector('.navbar__link') as HTMLElement;
          if (trigger) trigger.focus();
          const mega = item.querySelector('.mega') as HTMLElement;
          if (mega) {
            mega.style.opacity = '0';
            mega.style.pointerEvents = 'none';
            setTimeout(() => {
              mega.style.opacity = '';
              mega.style.pointerEvents = '';
            }, 200);
          }
        }
      });
    });

    // Hamburguesa — toggle mobile menu
    const burger = document.getElementById('burger-btn');
    if (burger) {
      burger.addEventListener('click', () => {
        const menu = document.getElementById('mobile-menu');
        if (menu) {
          menu.classList.toggle('open');
          const isOpen = menu.classList.contains('open');
          burger.setAttribute('aria-expanded', String(isOpen));
          document.body.style.overflow = isOpen ? 'hidden' : '';
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initNavbar);
  document.addEventListener('astro:after-swap', initNavbar);
</script>

<style>
  /* ===================================================
     NAVBAR BASE
     =================================================== */
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--gray-200);
    box-shadow: var(--shadow-xs);
    height: 68px;
  }

  .navbar.scrolled {
    box-shadow: var(--shadow-md);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    height: 100%;
  }

  /* ===================================================
     LOGO
     =================================================== */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    margin-right: 40px;
    flex-shrink: 0;
  }

  .navbar__logo-img {
    height: 40px;
    width: auto;
    display: block;
    border-radius: 6px;
  }

  /* ===================================================
     NAV PRINCIPAL
     =================================================== */
  .navbar__nav {
    flex: 1;
  }

  .navbar__list {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--gray-600);
    border-radius: var(--r-sm);
    transition: var(--transition);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    font-family: var(--font-body);
    background: none;
    border: none;
    line-height: 1.4;
  }

  .navbar__link:hover,
  .navbar__link:focus-visible {
    color: var(--red-500);
    background-color: var(--red-50);
  }

  /* Active state for Para ti trigger when mega panel is open */
  .navbar__link[aria-expanded="true"] {
    color: var(--red-500);
    background-color: var(--red-50);
  }

  .navbar__chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .navbar__link[aria-expanded="true"] .navbar__chevron {
    transform: rotate(180deg);
  }

  .navbar__item--has-mega:not(.navbar__item--para-ti):hover .navbar__chevron {
    transform: rotate(180deg);
  }

  /* ===================================================
     MEGA-PANEL — "Para ti" (wide panel, click-to-open)
     =================================================== */
  .mega-panel {
    position: fixed;
    top: 68px;
    left: 0;
    right: 0;
    background-color: var(--white);
    border-top: 1px solid var(--gray-200);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12), 0 4px 16px rgba(0, 0, 0, 0.06);
    z-index: 110;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s;
    max-height: calc(100vh - 68px);
    overflow-y: auto;
  }

  .mega-panel--open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-panel__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 24px 16px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 32px;
  }

  .mega-panel__section {
    padding: 0 0 20px;
    break-inside: avoid;
  }

  .mega-panel__heading {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 10px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--gray-100);
  }

